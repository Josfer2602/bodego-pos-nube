# Archivo de ejemplo para configuración de Base de Datos y Entorno
# Renombrar este archivo a ".env" en el servidor de producción (Hetzner)

# ==========================================
# CONFIGURACIÓN DE BASE DE DATOS
# ==========================================
# Formato PostgreSQL: postgresql://usuario:password@host:puerto/nombre_bd
# En local (SQLite), puedes dejar esto comentado o vacío para que use pos.db
DATABASE_URL=postgresql://admin_pos:tu_contraseña_segura@localhost:5432/pos_db

# ==========================================
# CONFIGURACIÓN DE SEGURIDAD (EJEMPLOS)
# ==========================================
# SECRET_KEY=tu_clave_secreta_super_segura
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=1440
