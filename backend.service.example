# Archivo de configuración de ejemplo para SystemD
# Copiar a /etc/systemd/system/backend.service
# Luego: sudo systemctl daemon-reload && sudo systemctl enable backend

[Unit]
Description=POS ERP Backend Service
After=network.target
Requires=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/app-ventas/backend
Environment="PATH=/var/www/app-ventas/backend/venv/bin"
Environment="PYTHONPATH=/var/www/app-ventas/backend"
ExecStart=/var/www/app-ventas/backend/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000 --workers 4
ExecReload=/bin/kill -s HUP $MAINPID

# Reinicio automático
Restart=always
RestartSec=5

# Límites de recursos
LimitNOFILE=65536
MemoryLimit=512M

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=pos-backend

[Install]
WantedBy=multi-user.target